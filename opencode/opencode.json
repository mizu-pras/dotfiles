{
  "$schema": "https://opencode.ai/config.json",
  "permission": "allow",
  "model": "openai/gpt-5.4",
  "small_model": "openai/gpt-5.4-mini",
  "mcp": {
    "zread": {
      "type": "remote",
      "url": "https://api.z.ai/api/mcp/zread/mcp",
      "headers": {
        "Authorization": "Bearer ZREAD_API_KEY"
      }
    }
  },
  "plugin": [
    "para-hyang@latest",
    "oh-my-opencode-slim@latest"
  ],
  "agent": {
    "explore": {
      "disable": true
    },
    "general": {
      "disable": true
    }
  }
}
